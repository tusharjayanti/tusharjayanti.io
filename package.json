{
  "name": "tusharjayanti.io",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:edge": "npm run sync:prompt && dotenv -e .env.local -- vercel dev",
    "build": "tsc -b && vite build",
    "vercel-build": "node scripts/inject-rewrite.mjs && npm run build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "sync:prompt": "node scripts/sync-prompt.mjs",
    "predev": "npm run sync:prompt",
    "prebuild": "npm run sync:prompt"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@upstash/redis": "^1.34.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "react-router": "^7.1.1",
    "resend": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
