{
  "name": "tusharjayanti.io",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "dev": "vite",
    "dev:edge": "npm run sync:prompt && dotenv -e .env.local -- vercel dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "dotenv -e .env.local -- vitest run --config vitest.integration.config.ts",
    "sync:prompt": "dotenv -e .env.local -- node scripts/sync-prompt.mjs",
    "ingest": "dotenv -e .env.local -- tsx scripts/rag/ingest.ts",
    "ingest:experience": "dotenv -e .env.local -- tsx scripts/rag/ingest-experience.ts",
    "ingest:resume": "dotenv -e .env.local -- tsx scripts/rag/ingest-resume.ts",
    "backfill:readmes": "dotenv -e .env.local -- tsx scripts/rag/backfill-readmes.ts",
    "smoke:retrieval": "dotenv -e .env.local -- tsx scripts/rag/smoke-retrieval.ts",
    "smoke:chat": "dotenv -e .env.local -- tsx scripts/rag/smoke-chat.ts",
    "eval:retrieval": "dotenv -e .env.local -- tsx scripts/eval/retrieval.ts",
    "test:lock-contention": "dotenv -e .env.local -- tsx scripts/test/lock-contention.ts",
    "predev": "npm run sync:prompt",
    "prebuild": "npm run sync:prompt"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@octokit/rest": "^22.0.1",
    "@supabase/supabase-js": "^2.106.1",
    "@upstash/redis": "^1.34.3",
    "@vercel/functions": "^3.6.0",
    "langfuse": "^3.38.20",
    "node-html-markdown": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0",
    "react-router": "^7.1.1",
    "resend": "^4.0.1",
    "voyageai": "0.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.6"
  }
}
