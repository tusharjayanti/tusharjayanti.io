# Complete env contract for tusharjayanti.io. Copy to .env.local and fill
# in values for any path you actually run (the api/ + cron paths need
# most; the RAG ingest scripts only need Supabase + Voyage). Sourced
# enforcement is at runtime: code throws if a required key is missing
# when its code path is exercised.

# Anthropic (chat)
ANTHROPIC_API_KEY=

# Upstash Redis (rate limiting, chat log, leak event store).
# Read implicitly by `Redis.fromEnv()` in api/_kv.ts and api/cron/digest.ts.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Langfuse (LLM observability — trace/generation/prompt registry).
# NOTE: source reads LANGFUSE_BASE_URL (not LANGFUSE_HOST).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Resend (canary leak alerting + daily digest cron).
RESEND_API_KEY=
LEAK_ALERT_FROM=
LEAK_ALERT_TO=
DIGEST_FROM=
DIGEST_EMAIL=

# Vercel cron auth header (api/cron/digest.ts gates on Bearer <CRON_SECRET>).
CRON_SECRET=

# Supabase (RAG storage — chunks table).
# SECRET_KEY has bypass-RLS privilege; server-side only, never ship to client.
# PUBLISHABLE_KEY is the anon key, documented here for future client-side reads.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Voyage AI (RAG embeddings — voyage-3, 1024-dim).
VOYAGE_API_KEY=

# --- Optional ---

# Local override for the per-deploy canary token. Without this set,
# scripts/sync-prompt.mjs generates a fresh canary on every build and
# produces a noisy diff on api/_systemPrompt.ts. Set it to a stable
# value during local dev.
CANARY_TOKEN=

# RAG retrieval — cosine-similarity floor for chunks returned to the
# tool_result. Chunks where (1 - semantic_distance) < this value are
# filtered out as the no-match fabrication guardrail (see api/_tools.ts
# NO_MATCH_TOOL_RESULT). Range 0–1; default 0.3 when unset. Threshold
# is on cosine similarity, NOT on the RRF blended score (which
# saturates near zero at k=60).
RAG_MIN_COSINE_SIMILARITY=

# Ops snippet cache TTL in seconds. /api/ops-snippet writes its
# aggregated blob to Redis with this TTL. Fresh-window is a separate
# 5-minute check inside the aggregator (cached blob counts as fresh
# if last_aggregated_at is within 5 minutes); this TTL only bounds
# how long the blob stays around between visits. Default 600 (10
# minutes) when unset.
OPS_SNIPPET_CACHE_TTL_SECONDS=
