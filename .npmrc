# Release config for `npm version <patch|minor|major>`.
# One atomic step bumps package.json + package-lock.json, creates a commit,
# and tags it — the tag is a byproduct of the bump, so the footer version
# (read from package.json) and the git tag can never drift.
#   npm version minor      -> 0.4.0 -> 0.5.0, commit, tag v0.5.0
#   git push --follow-tags -> pushes the commit and its tag together
message=chore(release): v%s
tag-version-prefix=v
